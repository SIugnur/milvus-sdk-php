{
    "name": "siugnur/milvus-sdk-php",
    "description": "PHP SDK for Milvus Vector Database",
    "type": "library",
    "require": {
        "php": "^8.0",
        "grpc/grpc": "^1.80",
        "google/protobuf": "^5.35"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "suggest": {
        "ext-grpc": "Required by grpc/grpc - C extension for high-performance gRPC communication",
        "ext-protobuf": "Faster protobuf serialization (optional, google/protobuf fallback works without it)"
    },
    "autoload": {
        "psr-4": {
            "Milvus\\SDK\\": "src/Milvus/SDK/",
            "Milvus\\Proto\\": "src/proto-php/Milvus/Proto/",
            "GPBMetadata\\": "src/proto-php/GPBMetadata/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Milvus\\SDK\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
